{
  "name": "testplaywright",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "test": "cucumber-js --config cucumber.json",
    "test:headed": "cucumber-js --config cucumber.json --world-parameters '{\"headless\":false}'",
    "pw:install": "playwright install --with-deps"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.0.0",
    "@playwright/test": "^1.52.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}